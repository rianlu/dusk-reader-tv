<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:angle="315"
                android:startColor="#11141B"
                android:centerColor="#1C2433"
                android:endColor="#090C12" />
        </shape>
    </item>
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#26FFFFFF" />
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:endColor="#14000000" />
        </shape>
    </item>
</layer-list>
